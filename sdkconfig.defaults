# Target: ESP32-S3 (set via: idf.py set-target esp32s3)
# Waveshare ESP32-S3-POE-ETH-8DI-8DO: 16MB flash, 8MB OCTAL PSRAM

CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"

# Enable PSRAM (8MB OPI/OCTAL on this board)
CONFIG_ESP32S3_SPIRAM_SUPPORT=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y

# Partition table: use custom to fit 16MB flash
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# WiFi
CONFIG_ESP_WIFI_SOFTAP_SUPPORT=y
# Reduce WiFi static TX buffer count from 16 (default) to 8.  Each static TX
# buffer is ~1600 B allocated from DIRAM (MALLOC_CAP_INTERNAL|MALLOC_CAP_DMA).
# BLE controller falls back to the 32 KB DMA pool for its 4 KiB EMI region
# (the DMA pool is untouched by WiFi TX buffers).
# 6 buffers caused SoftAP auth frame drops (wifi:m f auth) under concurrent BLE.
# 10 buffers exhausted the pvPortMalloc (INTERNAL-only) budget during NimBLE
# host init, crashing at ble_gap_init() mutex creation.  8 is the compromise:
# enough TX capacity to avoid auth drops, enough DRAM headroom for NimBLE —
# especially when combined with CONFIG_BT_NIMBLE_MEM_ALLOC_MODE_EXTERNAL=y.
# (Dynamic TX buffers are Kconfig-forbidden when SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y)
CONFIG_ESP_WIFI_STATIC_TX_BUFFER_NUM=8
# SPIRAM_TRY_ALLOCATE_WIFI_LWIP changes the RX buffer default from 10 to 16.
# 16 × 1600 B = 25.6 KB of INTERNAL|DMA, which leaves the DMA pool ~9.6 KB
# shorter for BLE controller allocations.  Pin it back to 10.
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=10

# Ethernet — enable built-in SPI Ethernet and W5500 driver
CONFIG_ETH_USE_SPI_ETHERNET=y
CONFIG_ETH_SPI_ETHERNET_W5500=y

# Logging
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# Disable mbedTLS hardware acceleration to avoid GDMA conflicts with I2C.
# RSA DS peripheral key only exists in IDF v6+, omitted here.
CONFIG_MBEDTLS_HARDWARE_SHA=n
CONFIG_MBEDTLS_HARDWARE_AES=n
CONFIG_MBEDTLS_HARDWARE_MPI=n

# --- Matter / esp-matter ---
# HKDF is required by the CHIP crypto PAL
CONFIG_MBEDTLS_HKDF_C=y

# BLE stack kept for Matter stack compatibility; advertising is disabled at
# runtime so the device uses mDNS/OnNetwork commissioning. This avoids the
# WiFi/BLE coexistence problem that stalls TCP connections on the HTTP server.
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_NIMBLE_ENABLE_CONN_REATTEMPT=n

# TCP send/receive buffers — default 5760 bytes is too small to serve static
# files without EAGAIN when the WiFi radio is intermittently busy.
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=16384
CONFIG_LWIP_TCP_WND_DEFAULT=16384

# IPv6 — Matter needs link-local + per-fabric ULAs
CONFIG_LWIP_IPV6_AUTOCONFIG=y
CONFIG_LWIP_IPV6_NUM_ADDRESSES=6
CONFIG_LWIP_HOOK_IP6_ROUTE_DEFAULT=y
CONFIG_LWIP_HOOK_ND6_GET_GW_DEFAULT=y

# 8 DO + 8 DI + root endpoint = 17; add margin
CONFIG_ESP_MATTER_MAX_DYNAMIC_ENDPOINT_COUNT=20

# Stack sizes — Matter initialization runs on app_main's stack and is deep;
# the CHIP task also needs more than the ESP-IDF default.
CONFIG_ESP_MAIN_TASK_STACK_SIZE=10240
CONFIG_CHIP_TASK_STACK_SIZE=15360
CONFIG_BT_NIMBLE_TASK_STACK_SIZE=5120
# NimBLE host pool buffers (event queues, callouts, mutexes, semaphores) go to
# PSRAM with EXTERNAL mode, freeing ~5-10 KiB of internal DRAM for FreeRTOS
# Queue_t / Timer_t objects (pvPortMalloc = INTERNAL-only, no PSRAM fallback).
# With SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y the INTERNAL budget is tight; EXTERNAL
# mode is what gives 8 WiFi TX buffers enough headroom to coexist with BLE.
# BLE controller uses bt_osi_mem_calloc_internal which ignores this setting.
CONFIG_BT_NIMBLE_MEM_ALLOC_MODE_EXTERNAL=y

# mbedTLS BIGNUM/ECC workspace exhausts internal DRAM during NOC chain
# verification (AddNOC step of Matter commissioning).  DEFAULT mode falls
# back to PSRAM when internal DRAM is exhausted.  BIGNUM/ECC operations are
# pure CPU — no DMA — so PSRAM is safe here.
CONFIG_MBEDTLS_DEFAULT_MEM_ALLOC=y

# PSRAM heap routing — Matter makes many large allocations that exhaust
# internal DRAM (leaving none for httpd/mqtt task stacks).  Route any
# allocation larger than 4 KiB to PSRAM when internal RAM is full.
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=4096
# Allow FreeRTOS tasks (httpd, mqtt, etc.) to allocate their stacks in PSRAM
# when internal DRAM is exhausted.
CONFIG_SPIRAM_ALLOW_STACK_EXTERNAL_MEMORY=y
# Move WiFi static RX buffers (~16 KB) and the lwIP pbuf pool to PSRAM.
# Without this, those pools sit in internal DRAM and fragment it so severely
# that the W5500 SPI driver can no longer allocate its ~1500-byte DMA bounce
# buffers (MALLOC_CAP_INTERNAL|DMA) — causing continuous TX errors under load.
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y

# The on_wifi_ready callback runs in the FreeRTOS timer service task
# (wifi-bootstrap fires it from a TimerHandle_t callback).  The default
# 2048 bytes is far too small: httpd_start() + ESP_LOGE overflow it.
CONFIG_FREERTOS_TIMER_TASK_STACK_DEPTH=8192

# httpd stack must be > SPIRAM_MALLOC_ALWAYSINTERNAL (4096) so it lands in
# PSRAM when internal DRAM is exhausted by Matter.
CONFIG_HTTPD_STACK_SIZE=6144

# OTA requestor (needed by esp_matter_ota_provider component)
CONFIG_ENABLE_OTA_REQUESTOR=y

# Matter device identification strings (VendorID 0xFFF1 is the CSA test VID)
CONFIG_CHIP_PROJECT_CONFIG="main/CHIPProjectConfig.h"
